# Backend Selection (claude-cli | opencode-cli | openrouter)
AUTOIDEATOR_BACKEND=claude-cli

# OpenRouter API Key (required if using openrouter backend)
OPENROUTER_API_KEY=your-api-key-here

# OpenRouter API base URL
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Default model for OpenRouter
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Maximum plan refinement iterations
MAX_PLAN_REFINEMENTS=12

# Maximum improvement discovery iterations per cycle
MAX_IMPROVEMENT_ITERATIONS=5

# Enable verbose logging
VERBOSE=false

# Git commit author
GIT_AUTHOR_NAME=AutoIdeator
GIT_AUTHOR_EMAIL=autoideator@localhost
